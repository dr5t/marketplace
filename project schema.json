{
    "project_name": "Vrindaa Crochet Marketplace",
    "project_type": "Full Stack Multi-Vendor Marketplace (Web + Mobile)",
    "core_goal": "Build a production-ready crochet marketplace with user, seller, and admin roles, including AI recommendations and a premium iOS-style Liquid UI design system",
    "platforms": {
        "web": {
            "framework": "Next.js (App Router)",
            "language": "TypeScript",
            "styling": "Tailwind CSS + ShadCN UI",
            "animations": "Framer Motion"
        },
        "mobile": {
            "framework": "React Native (Expo)",
            "styling": "NativeWind",
            "navigation": "React Navigation",
            "animations": "React Native Reanimated"
        }
    },
    "backend": {
        "runtime": "Node.js",
        "framework": "Express or Next.js API Routes",
        "authentication": [
            "JWT (access + refresh tokens)",
            "Google OAuth"
        ]
    },
    "database": {
        "type": "PostgreSQL",
        "orm": "Prisma",
        "models": [
            "User",
            "SellerProfile",
            "Product",
            "Category",
            "Order",
            "OrderItems",
            "Review",
            "Cart",
            "Wishlist"
        ]
    },
    "storage": {
        "images": "Cloudinary or AWS S3"
    },
    "payments": {
        "providers": [
            "Stripe",
            "Razorpay"
        ]
    },
    "roles": [
        "Guest",
        "User (Buyer)",
        "Seller (Vendor)",
        "Admin (Super Admin)"
    ],
    "features": {
        "user": [
            "Browse products",
            "Advanced search and filters",
            "Product detail page",
            "Add to cart",
            "Wishlist",
            "Checkout",
            "Order tracking",
            "Reviews and ratings",
            "AI recommendations"
        ],
        "seller": [
            "Seller dashboard",
            "Add/edit/delete products",
            "Image upload",
            "Order management",
            "Inventory management",
            "Sales analytics",
            "Chat with buyers"
        ],
        "admin": [
            "Dashboard analytics",
            "User management",
            "Seller approval",
            "Product moderation",
            "Order monitoring",
            "Revenue tracking",
            "Category management"
        ]
    },
    "ai_features": [
        "Recommendation engine (collaborative filtering)",
        "Smart search (fuzzy + semantic)",
        "Trending product detection",
        "Optional chatbot"
    ],
    "ui_design_system": {
